{
  "name": "travel-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "doctor": "node scripts/doctor.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:sync": "powershell -NoProfile -Command \"Copy-Item database/migrations/*.sql supabase/migrations/ -Force\"",
    "db:bundle": "node scripts/bundle-sql.mjs",
    "db:push": "npm run db:sync && npx supabase db push",
    "admin:create": "node scripts/create-admin-user.mjs",
    "db:seed": "node scripts/seed-demo-data.mjs",
    "db:seed:validate": "node scripts/seed-demo-data.mjs --validate-only",
    "e2e:ci-prep": "node scripts/e2e-ci-prep.mjs",
    "test:email": "tsx --test src/lib/email/templates.test.ts",
    "test:auth-bearer": "tsx --test src/lib/auth/parse-bearer-token.test.ts",
    "test:events": "tsx --test src/lib/events/events.test.ts",
    "gate:sprint7b:foundation": "node scripts/run-sprint7b-foundation-gate-http.mjs",
    "test:crm-rls": "node scripts/test-crm-rls.mjs",
    "test:customer360-gate": "node scripts/validate-customer360-gate.mjs",
    "gate:sprint5:seed": "node scripts/sprint5-gate-seed-heavy-customer.mjs",
    "gate:sprint5:http": "node scripts/run-sprint5-gate-http.mjs",
    "test:sprint5-gate": "node scripts/sprint5-gate-seed-heavy-customer.mjs && node scripts/run-sprint5-gate-http.mjs && playwright test e2e/customer360-gate.spec.ts --project=gate",
    "gate:sprint6:dashboard": "node scripts/run-sprint6-dashboard-gate-http.mjs",
    "apply:034:verify": "node scripts/apply-034-dashboard-rpc.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "gate:portal": "node scripts/run-portal-gate-http.mjs",
    "gate:sprint9a:payments": "node scripts/run-sprint9a-payment-gate.mjs",
    "test:payments": "tsx --test src/lib/payments/payments.test.ts",
    "gate:sprint8c:events": "node scripts/run-sprint8c-events-gate.mjs",
    "gate:sprint8d:worker": "node scripts/run-sprint8d-worker-gate.mjs",
    "gate:sprint9b:whatsapp": "node scripts/run-sprint9b-whatsapp-gate.mjs",
    "gate:sprint9c:sales-ai": "node scripts/run-sprint9c-sales-ai-gate.mjs",
    "gate:sprint9d:operations-ai": "node scripts/run-sprint9d-operations-ai-gate.mjs",
    "gate:commercial": "node scripts/run-commercial-journey-gate.mjs",
    "gate:production-matrix": "node scripts/run-production-verification-matrix.mjs",
    "verify:worker-health": "node scripts/verify-worker-health.mjs",
    "validate:production-env": "node scripts/validate-production-env.mjs",
    "test:sales-ai": "tsx --test src/lib/sales-ai/sales-ai.test.ts",
    "test:operations-ai": "tsx --test src/lib/operations-ai/operations-ai.test.ts",
    "test:whatsapp": "tsx --test src/lib/whatsapp/whatsapp.test.ts",
    "test:sprint8c": "npm run test:events && npm run gate:sprint8c:events",
    "test:sprint8d": "npm run test:events && npm run gate:sprint8d:worker"
  },
  "dependencies": {
    "@fontsource/noto-sans-arabic": "^5.2.10",
    "@react-pdf/renderer": "^4.5.1",
    "@refinedev/core": "^4.57.0",
    "@refinedev/nextjs-router": "^6.0.0",
    "@refinedev/react-hook-form": "^4.9.0",
    "@refinedev/react-table": "^5.6.0",
    "@refinedev/supabase": "^5.9.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-table": "^8.21.2",
    "@travelos/external-react": "file:packages/external-react",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.483.0",
    "next": "^15.2.4",
    "next-intl": "^4.13.0",
    "nodemailer": "^8.0.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "recharts": "^2.15.0",
    "resend": "^6.12.4",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^5.8.2"
  }
}
