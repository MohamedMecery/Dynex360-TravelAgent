{
  "name": "travel-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:3001": "next dev -p 3001",
    "doctor": "node scripts/doctor.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:sync": "powershell -NoProfile -Command \"Copy-Item database/migrations/*.sql supabase/migrations/ -Force\"",
    "db:bundle": "node scripts/bundle-sql.mjs",
    "db:push": "npm run db:sync && npx supabase db push",
    "admin:create": "node scripts/create-admin-user.mjs",
    "db:seed": "node scripts/seed-demo-data.mjs",
    "db:seed:validate": "node scripts/seed-demo-data.mjs --validate-only",
    "e2e:ci-prep": "node scripts/e2e-ci-prep.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@refinedev/core": "^4.57.0",
    "@refinedev/nextjs-router": "^6.0.0",
    "@refinedev/react-hook-form": "^4.9.0",
    "@refinedev/react-table": "^5.6.0",
    "@refinedev/supabase": "^5.9.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@tanstack/react-table": "^8.21.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.483.0",
    "next": "^15.2.4",
    "next-intl": "^4.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.54.2",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.4",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2"
  }
}
