# Supabase Cloud (recommended)
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon key also works:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — for npm run admin:create, gates, worker (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# Canonical app URL (email links, portal, auth redirects) — required in production
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
# Optional alias used by payment checkout return URLs
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Sprint 8D — async dispatch worker (POST /api/cron/process-dispatch-jobs)
CRON_SECRET=

# Sprint 9A — Paymob (mock when PAYMOB_MOCK_MODE=true or API key unset)
# PAYMOB_API_KEY=
# PAYMOB_INTEGRATION_ID=
# PAYMOB_IFRAME_ID=
# PAYMOB_HMAC_SECRET=
PAYMOB_MOCK_MODE=true
PAYMOB_MOCK_WEBHOOKS=true
# NEXT_PUBLIC_PAYMOB_MOCK_MODE=true

# Sprint 9B — WhatsApp Meta Cloud API (mock when WHATSAPP_MOCK_MODE=true or token unset)
WHATSAPP_MOCK_MODE=true
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_META_API_VERSION=v21.0

# Transactional email (Resend default)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# AI agents (server-only — never expose to browser)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Gate scripts (development only — do not set on Vercel Production)
# GATE_BASE_URL=http://localhost:3000
# GATE_TEST_PASSWORD=TravelOS@2026
# PORTAL_TEST_EMAIL=portal-customer@demo.travelos.local

# --- Local Supabase (requires Docker Desktop) ---
# npx supabase start && npx supabase status
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# First admin: npm run admin:create
# ADMIN_EMAIL=eng.m.mecery@gmail.com
# ADMIN_PASSWORD=YourSecurePassword
