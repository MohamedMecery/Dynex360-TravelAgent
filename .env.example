# Supabase Cloud (recommended)
# Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Legacy anon key also works:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-only — for npm run admin:create (never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# AI agents (server-only — never expose to browser)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Local Supabase (requires Docker Desktop) ---
# npx supabase start && npx supabase status
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# First admin: npm run admin:create
# ADMIN_EMAIL=eng.m.mecery@gmail.com
# ADMIN_PASSWORD=YourSecurePassword
