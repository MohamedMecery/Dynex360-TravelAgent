      "title": "الأسئلة الشائعة",
      "subtitle": "ما تحتاج معرفته قبل انضمام وكالتك.",
      "q1": {
        "question": "لمن صُمم TravelOS؟",
        "answer": "للوكالات السياحية ومنظمي الرحلات وشركات إدارة الوجهات التي تحتاج منصة آمنة متعددة المستأجرين للعملاء والباقات والحجوزات والمدفوعات."
      },
      "q2": {
        "question": "هل يدعم العربية و RTL؟",
        "answer": "نعم. الواجهة تدعم الإنجليزية والعربية مع تخطيط من اليمين لليسار، بما في ذلك الموقع التسويقي والتطبيق."
      },
      "q3": {
        "question": "كيف يعمل الأمان متعدد المستأجرين؟",
        "answer": "كل وكالة معزولة كمستأجر. أمان على مستوى الصفوف في قاعدة البيانات ومطالبات JWT والصلاحيات تضمن رؤية بيانات المنظمة فقط."
      },
      "q4": {
        "question": "ماذا يفعل مساعد السفر الذكي؟",
        "answer": "يساعد على تحويل استفسارات العملاء إلى مسودات حجز منظمة. الموظفون يراجعون ويؤكدون دائماً — لا تأكيد تلقائي في MVP."
      },
      "q5": {
        "question": "هل يمكن الانتقال من جداول أو أنظمة قديمة؟",
        "answer": "نعم. عند الانضمام نساعد في استيراد العملاء والباقات وضبط الأدوار وتدريب الفريق."
      },
      "q6": {
        "question": "هل توجد تجربة مجانية؟",
        "answer": "سجّل الدخول لطلب الوصول أو بدء تجربة موجهة. خطط Enterprise تشمل انضماماً مخصصاً وشروطاً خاصة."
      }
    },
