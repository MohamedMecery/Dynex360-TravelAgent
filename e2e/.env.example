# Optional overrides for Playwright E2E (copy to .env.e2e.local)
# Credentials must match a provisioned tenant admin (npm run admin:create)

E2E_BASE_URL=http://localhost:3099
E2E_PORT=3099
E2E_ADMIN_EMAIL=admin@your-agency.example
E2E_ADMIN_PASSWORD=change-me-after-admin-create

# Set when dev server is already running:
# E2E_SKIP_WEBSERVER=1
